# ==============================================================
# Cấu hình kết nối SQL Server - BanVeTauNhaGa
# Chỉnh sửa file này theo môi trường của bạn
# QUAN TRỌNG: Không commit file .env lên Git (đã có trong .gitignore)
# ==============================================================

# Host của SQL Server (localhost hoặc IP máy chủ)
DB_HOST=localhost

# Cổng SQL Server (mặc định 1433)
DB_PORT=1433

# Tên database
DB_NAME=BanVeTauNhaGa

# Tên đăng nhập SQL Server Authentication
DB_USER=sa

# Mật khẩu SQL Server
DB_PASSWORD=YourPassword123
